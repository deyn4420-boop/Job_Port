PORT=5000
NODE_ENV=development

MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/job-portal

# Use long, random strings in production (openssl rand -base64 64)
JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_strong_random_secret

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CLIENT_URL=http://localhost:3000

# Used for AI resume-to-job match scoring. If unset, applications still work
# without match scores.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
